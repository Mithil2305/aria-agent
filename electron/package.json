{
	"name": "yukti",
	"version": "1.0.0",
	"description": "Yukti - Decision Intelligence for Indian SMBs",
	"author": "Mud Media",
	"main": "main.js",
	"scripts": {
		"start": "electron .",
		"dist": "electron-builder --win --x64",
		"dist:signed": "electron-builder --win --x64 --publish always"
	},
	"dependencies": {
		"electron-log": "^5.2.4",
		"electron-updater": "^6.3.9"
	},
	"devDependencies": {
		"electron": "^31.0.0",
		"electron-builder": "^24.0.0"
	},
	"build": {
		"appId": "com.yukti.app",
		"productName": "Yukti",
		"artifactName": "${productName} Setup ${version}.${ext}",
		"win": {
			"target": "nsis",
			"icon": "assets/icon.ico"
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true
		},
		"extraResources": [
			{
				"from": "../backend/dist/yukti-backend.exe",
				"to": "backend/yukti-backend.exe"
			}
		],
		"publish": [
			{
				"provider": "github",
				"owner": "Mithil2305",
				"repo": "aria-agent"
			}
		]
	}
}
